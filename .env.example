# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Database ----
DATABASE_URL=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ---- Crawl behaviour ----
CLASSIFY_BATCH_SIZE=20
DEFAULT_CRAWL_HOURS=1

# ---- HTTP client ----
HTTP_TIMEOUT=30

# ---- LLM retry ----
LLM_MAX_RETRIES=3

# ---- Logging ----
LOG_LEVEL=INFO
